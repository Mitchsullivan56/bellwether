# Copy this to .streamlit/secrets.toml for local testing (that file is gitignored),
# OR paste these keys into Streamlit Cloud → your app → Settings → Secrets.
#
# BUTTONDOWN_API_KEY: from buttondown.com → Settings → Programming → API.
#   When set, email signups go to Buttondown instead of the local CSV.
# DEPLOYED: "1" hides the in-app Refresh button (the GitHub Action handles updates).
#   It's implied automatically when BUTTONDOWN_API_KEY is present.

BUTTONDOWN_API_KEY = "your-buttondown-api-key"
DEPLOYED = "1"
